def main():
    parser = argparse.ArgumentParser(prog="homl")
    subparsers = parser.add_subparsers(dest="command", required=True)
    add_parser = subparsers.add_parser("add", help="Install a package")
    add_parser.add_argument("package", help="Package name")
    add_parser.add_argument("--version", help="Specific version")

    remove_parser = subparsers.add_parser("remove", help="Remove a package")
    remove_parser.add_argument("package", help="Package name")

    args = parser.parse_args()
    if args.command == "add":
        cmd_add(args.package, args.version)
    elif args.command == "remove":
        cmd_remove(args.package)
    else:
        parser.print_help()

if __name__ == "__main__":
    main()