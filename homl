#!/usr/bin/env python3
import os
import sys
import yaml
import hashlib
import shutil
import tempfile
import urllib.request
import argparse
from pathlib import Path

CONFIG_DIR = Path.home() / ".homl"
CONFIG_DIR.mkdir(exist_ok=True)
INSTALL_PREFIX = CONFIG_DIR / "root"
INSTALL_PREFIX.mkdir(exist_ok=True)
BIN_DIR = INSTALL_PREFIX / "bin"
BIN_DIR.mkdir(exist_ok=True)

# 默认索引 URL（替换为你的 R2 公共 URL）
INDEX_URL = "https://pub-xxxxxxxxxxxxx.r2.dev/index.yaml"

def update_index():
    """下载最新的 index.yaml 到缓存"""
    cache_file = CONFIG_DIR / "index.yaml"
    try:
        urllib.request.urlretrieve(INDEX_URL, cache_file)
        print("Index updated.")
    except Exception as e:
        print(f"Failed to download index: {e}")
        sys.exit(1)
    with open(cache_file, 'r') as f:
        return yaml.safe_load(f)

def download_and_install(pkg_name, version, index):
    pkg_info = index["packages"][pkg_name]["versions"][version]
    url = pkg_info["download_url"]
    expected_sha = pkg_info["checksum"].split(":")[1]

    print(f"Downloading {pkg_name} {version}...")
    with tempfile.NamedTemporaryFile(delete=False) as tmp:
        urllib.request.urlretrieve(url, tmp.name)
        # 校验和
        sha = hashlib.sha256(open(tmp.name, "rb").read()).hexdigest()
        if sha != expected_sha:
            print(f"Checksum mismatch! Expected {expected_sha}, got {sha}")
            os.unlink(tmp.name)
            sys.exit(1)
        # 解压 .homl (tar.xz)
        import tarfile
        with tarfile.open(tmp.name, "r:xz") as tar:
            tar.extractall(INSTALL_PREFIX)
        print(f"Installed {pkg_name} {version} into {INSTALL_PREFIX}")
        os.unlink(tmp.name)
    
    # 可选：将 bin 目录添加到 PATH 提示
    print(f"Add {BIN_DIR} to your PATH: export PATH={BIN_DIR}:$PATH")

def cmd_add(pkg_name, version=None):
    index = update_index()
    if pkg_name not in index["packages"]:
        print(f"Package {pkg_name} not found.")
        sys.exit(1)
    pkg_versions = index["packages"][pkg_name]["versions"]
    if version is None:
        # 取最新版本（字符串比较）
        version = max(pkg_versions.keys())
    if version not in pkg_versions:
        print(f"Version {version} not available for {pkg_name}")
        sys.exit(1)
    # TODO: 依赖解析与安装（简化版先略过）
    download_and_install(pkg_name, version, index)

